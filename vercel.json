{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.telisik.org/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://api.telisik.org/auth/:path*"
    },
    {
      "source": "/articles/:path*",
      "destination": "https://api.telisik.org/articles/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://api.telisik.org/static/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.telisik.org/media/:path*"
    }
  ]
}
